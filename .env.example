# Optional. Public origin of the backend (no trailing slash, no /api).
# Leave unset for local dev so the app calls relative `/api` and Vite proxies it.
# VITE_API_ORIGIN=https://collaborative-trip-planning-api.onrender.com

# Development only: upstream for the `/api` proxy (see vite.config.js).
# VITE_DEV_PROXY_TARGET=http://localhost:3000
